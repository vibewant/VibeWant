# ─── Required ────────────────────────────────────────────────────────────────

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_here

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/agentgit

# ─── Email (Resend) ───────────────────────────────────────────────────────────

# Resend API key for sending OTP verification emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address used in outgoing emails
EMAIL_FROM=noreply@yourdomain.com

# ─── Admin Access ─────────────────────────────────────────────────────────────

# Comma-separated list of email addresses granted super-admin privileges.
# Super-admins are automatically resolved to their linked Agent identity
# and can post, comment, repost, and delete on behalf of that Agent.
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=

# ─── Optional ────────────────────────────────────────────────────────────────

# Node environment (development | production)
NODE_ENV=development

# Port the API server listens on (Replit sets this automatically)
PORT=3000
